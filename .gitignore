# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
.venv*/
venv/

# Tooling
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Secrets — never commit credentials
.secrets/
.env
*.key

# robolabel outputs (annotations, extracted frames, receipts, gold sets)
*.annotations/
annotations.parquet
human_annotations.parquet
raw_receipts/
subgoal_frames/
demo_out/

# strategy-ablation working dir (large, regenerable: receipts, per-cell segments).
# eval/so101_split.json is the frozen split; the machine results JSONs are regenerable.
eval_out/
eval_out_grip/

# OS
.DS_Store

# supplementary metrics (regenerable via scripts/compute_metrics.py)
eval_metrics/

# inspect viewer data (regenerable via scripts/build_inspect_data.py; embeds the local gold)
inspect_data/
fresh_*/
grades*.json

# spot-check montages (regenerable via scripts/spotcheck_frames.py)
spotcheck/
# cross-task probe working dir (regenerable; receipts + frames, embeds no gold)
probe_*/
# run logs (regenerable)
*.log
# gallery config (regenerable via scripts/make_gallery.py; references local inspect_data)
gallery.json

# run-config outputs (regenerable)
run_out/

# ---------------------------------------------------------------------------
# Repo hygiene: ship the functionality + its user docs, not the internal process.
# The repo tracks the package (src/), packaging, and the user-facing docs
# (README, CONFIG, SCHEMA, PORTING). Everything below is kept locally but gated
# out of the commit so internal reports / tests / helper scripts never re-enter.
# ---------------------------------------------------------------------------

# Internal reports, audits, and process notes (regenerable / local-only).
/CHANGELOG.md
/CLAIMS.md
/FRESH_TRIAL_REPORT.md
/MIGRATION_MAP.md
/OUTREACH.md
/PRICE_EFFICIENCY.md
/RELEASE_READINESS.md
/REVIEW_GUIDE.md
/ROADMAP.md
/RUN_SUMMARY.md
/STRATEGY_REPORT.md
# ...and report-/summary-like docs in general, so new ones don't sneak in.
*_REPORT.md
*_SUMMARY.md
RUN_*.md

# Internal prose docs. The docs/ folder is internal; only the one figure the README
# embeds (the GIF) is kept tracked.
/docs/*
!/docs/figures/
/docs/figures/*
!/docs/figures/grounded_annotations.gif

# Tests and helper/build scripts — not part of the installed package.
/tests/
/scripts/

# Loose generated metric artifacts.
/probe_metrics.json
*_metrics.json
